{
  "name": "kos-cli",
  "version": "0.1.0",
  "description": "Knowledge Operating System CLI v0 — validate, ingest, compile, and run controlled documentation tasks against a KOS vault.",
  "type": "module",
  "bin": {
    "kos": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/workers/prompts','dist/workers/prompts',{recursive:true})\"",
    "kos": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
